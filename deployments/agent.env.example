SING_PANEL_API_URL=https://panel.example.com
SING_PANEL_NODE_ID=exit_xxxxxxxxxxxx
SING_PANEL_AGENT_TOKEN=copy-from-panel-node
SING_PANEL_API_BASIC_USER=admin
SING_PANEL_API_BASIC_PASS=choose-a-strong-password

SING_PANEL_AGENT_RUNTIME_DIR=/var/lib/sing-panel-agent
SING_PANEL_AGENT_STATS_MODE=auto
SING_PANEL_AGENT_INTERVAL=10s
SING_PANEL_AGENT_CHECK_CONFIG=true
SING_PANEL_SING_BOX_BIN=/usr/local/bin/sing-box
SING_PANEL_SING_BOX_SERVICE=sing-box.service

# Set this only when the Exit node ACME DNS01 config references this env name.
# CLOUDFLARE_API_TOKEN=replace-me
