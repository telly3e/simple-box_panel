PANEL_HTTP_PORT=8080

# API process defaults. The container image uses the same variables by default.
SING_PANEL_ADDR=:8080
SING_PANEL_DB=/data/sing-panel.db
SING_PANEL_WEB_DIR=/app/web

# Used only when the optional Caddy reverse proxy profile is enabled.
PANEL_DOMAIN=panel.example.com
PANEL_BASIC_AUTH_USER=admin
# Generate with: caddy hash-password --plaintext 'replace-me'
PANEL_BASIC_AUTH_HASH=replace-with-a-real-caddy-hash
